# Agent Agora — 환경 변수 예시
# 이 파일을 '.env' 로 복사하고 본인 키를 채우세요. '.env' 는 .gitignore 에
# 들어 있어 커밋되지 않습니다. 모든 키는 선택 — 사용하는 공급자만 채우세요.

# =============================================================================
# LLM 공급자 API 키
# =============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# --- Ollama (로컬 LLM · 선택) ---
# 기본 호스트(http://localhost:11434) 외에서 돌리면 명시.
# OLLAMA_HOST=http://localhost:11434


# =============================================================================
# 인프라 (선택)
# =============================================================================
# 기본은 작업 디렉터리의 SQLite 파일(./agora.db). Postgres 도 가능.
# DATABASE_URL=sqlite+aiosqlite:///./agora.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/agora


# =============================================================================
# 토론 동작 튜닝 (선택)
# =============================================================================
# 동시 LLM 호출 상한 — CPU 폭주·낙관적 락 경합을 막는 백프레셔 (기본 8).
# AGORA_MAX_CONCURRENT_LLM=8

# 전원 manual 토론에서 시스템 LLM 호출(단계 요약·합의 근접도)에 쓸 폴백 모델.
# OPENAI_API_KEY 가 있어야 동작 (기본 gpt-4o-mini).
# AGORA_FALLBACK_MODEL=gpt-4o-mini

# 수동 아카이브('📄 텍스트 저장') 가 .md 를 떨굴 폴더 (기본 discussions/).
# AGORA_ARCHIVE_DIR=discussions
